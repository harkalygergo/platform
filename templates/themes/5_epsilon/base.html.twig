<!DOCTYPE html>
<html lang="{{ language|default('en') }}">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="keywords" content="{{ keywords }}">
    <meta name="description" content="{{ description }}">
    <meta name="robots" content="{{ website.metaRobots|default('index, follow') }}">

    <!-- prevent caching to ensure latest content is always displayed -->
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">

    <title>{{ title }}</title>

    <link rel="stylesheet" type="text/css" href="https://cdn.brandcomstudio.com/vendor/twbs/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.brandcomstudio.com/vendor/twbs/bootstrap-icons/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

    {% if website.favicon != null %}
        <link rel="icon" type="image/png" href="/media/{{ website.favicon.originalName }}">
    {% else %}
        <link rel="icon" type="image/png" href="{{ asset('favicon.png') }}">
    {% endif %}

    <style>
        body {
            font-family: "Poppins", sans-serif;
            background-color: {{ website.backgroundColor|default('#ffffff') }};
            color: {{ website.textColor|default('#000000') }};
        }

        {{ website.headerCSS|raw }}
    </style>
    <script>
        {{ website.headerJS|raw }}
    </script>
    {{ website.headerHTML|raw }}


    <script>
        function postData(url, data) {
            // Convert object to URL-encoded form data (like $_POST)
            const formBody = Object.keys(data)
                .map(key => encodeURIComponent(key) + '=' + encodeURIComponent(data[key]))
                .join('&');

            return fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: formBody,
            })
                //.then(response => response.json()) // or .text() if not JSON
                .catch(error => console.error('Error:', error));
        }






        async function getData(APIKey) {
            const url = "https://platform.harkalygergo.hu/api/?honeypot&action=cart&key="+APIKey;
            try {
                const response = await fetch(url);
                if (!response.ok) {
                    throw new Error(`Response status: ${response.status}`);
                }

                const result = await response.json();
                console.log(result);
            } catch (error) {
                console.error(error.message);
            }
        }


        function getCartContents() {
            const match = document.cookie.match(/(^| )cart=([^;]+)/);
            return match ? JSON.parse(decodeURIComponent(match[2])) : [];
        }

        function checkout(APIKey)
        {
            const cartContents = getCartContents();
            const checkoutDOM = document.getElementById('checkout');

            let checkoutDOMContent = '';
            for (const cartItem of cartContents) {
                checkoutDOMContent += cartItem.name+" - "+cartItem.price+" - "+cartItem.qty+" - "+cartItem.price*cartItem.qty+"<br>";
            }
            checkoutDOM.innerHTML = checkoutDOMContent;

            //getData(APIKey);



            // create an ajax

            //alert("csekót");

            // Usage
            postData('https://platform.harkalygergo.hu/api/', {
                honeypot: '',
                action: 'checkout',
                key: APIKey,
                cart: checkoutDOMContent
            }).then(response => response.text())
                .then(html => {
                    checkoutDOM.innerHTML = html;
                });

            console.log(cartContents);
            //alert("vége");
        }
    </script>



</head>
<body class="bg-white">

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="container">

                <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start py-4">
                    <a href="/" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto link-body-emphasis text-decoration-none">
                        {% if website.logo %}
                            <img src="/media/{{ website.logo.originalName }}" alt="{{ website.name }} logo" class="me-2" style="max-height: 3rem;">
                        {% endif %}
                        <span class="fs-4 fw-bold">{{ website.name }}</span>
                    </a>

                    {% block navigation %}
                    {% endblock %}

                    <div class="text-end">
                        {% if website.bluesky != null and website.bluesky != '' %}
                            <a href="{{ website.bluesky }}" class="text-white text-decoration-none p-2" target="_blank" title="Bluesky"><i class="fs-4 bi bi-bluesky"></i></a>
                        {% endif %}
                        {% if website.facebook != null and website.facebook != '' %}
                            <a href="{{ website.facebook }}" class="text-white text-decoration-none p-2" target="_blank" title="Facebook"><i class="fs-4 bi bi-facebook"></i></a>
                        {% endif %}
                        {% if website.instagram != null and website.instagram != '' %}
                            <a href="{{ website.instagram }}" class="text-white text-decoration-none p-2" target="_blank" title="Instagram"><i class="fs-4 bi bi-instagram"></i></a>
                        {% endif %}
                        {% if website.linkedin != null and website.linkedin != '' %}
                            <a href="{{ website.linkedin }}" class="text-white text-decoration-none p-2" target="_blank" title="LinkedIn"><i class="fs-4 bi bi-linkedin"></i></a>
                        {% endif %}
                        {% if website.threads != null and website.threads != '' %}
                            <a href="{{ website.threads }}" class="text-white text-decoration-none p-2" target="_blank" title="Threads"><i class="fs-4 bi bi-threads"></i></a>
                        {% endif %}
                        {% if website.twitter != null and website.twitter != '' %}
                            <a href="{{ website.twitter }}" class="text-white text-decoration-none p-2" target="_blank" title="X (Twitter)"><i class="fs-4 bi bi-twitter-x"></i></a>
                        {% endif %}

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

{% block header %}
{% endblock %}

{#% include 'themes/4_delta/header.html.twig' %#}

{% block body %}
{% endblock %}

{% include 'themes/5_epsilon/footer.html.twig' %}

<script src="https://cdn.brandcomstudio.com/vendor/twbs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<!-- Generated: {{ 'now'|date('Y.m.d. H:i:s | U') }} -->

</body>
</html>
