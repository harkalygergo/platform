<ul class="nav nav-pills">
    {% if productCategories is defined and productCategories is not null %}
        <li class="dropdown">
            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Kategóriák
            </a>
            <ul class="dropdown-menu bg-white">
                {% for productCategory in productCategories %}
                    <li>
                        <a class="dropdown-item text-dark" href="/termekkategoria/{{ productCategory.slug }}">
                            {{ productCategory.name }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </li>
    {% endif %}
    {% for menu in menus %}
        {% if menu.parent is null %}
            {% if menu.hasChildren() %}
                {# Parent menu with children - render as dropdown #}
                <li class="dropdown">
                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ menu.title }}
                    </a>
                    <ul class="dropdown-menu bg-white">
                        {% for child in menu.children %}
                            {% if child.status %}
                                <li><a class="dropdown-item text-dark" href="{{ child.slug }}">{{ child.title }}</a></li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </li>
            {% else %}
                {# Simple menu item without children #}
                <li>
                    <a class="nav-link text-dark" aria-current="page" href="{{ menu.slug }}">{{ menu.title }}</a>
                </li>
            {% endif %}
        {% endif %}
    {% endfor %}
</ul>
