{% extends 'themes/5_epsilon/base.html.twig' %}

{% block navigation %}
    {% include 'themes/5_epsilon/_navigation.html.twig' with { 'menus':menus } %}
{% endblock %}

{% block body %}

    <div class="container">
        <div class="row p-2">
            <div class="col-md-6">
                {% if product.mainImage is not null %}
                    <img src="/media/{{ product.mainImage.originalName }}" alt="{{ product.name }}" class="img-fluid">
                {% endif %}
            </div>
            <div class="col-md-6">
                <h1>{{ product.name }}</h1>

                <p class="lead">{{ product.shortDescription|raw }}</p>
                <p>Ár: {{ product.price|format() }} {{ product.currency }}</p>

                <div class="d-grid gap-2">
                    <a href="#" class="btn btn-dark btn-fluid" onclick="addToCart('{{ product.name }}', {{ product.price }});"><i class="bi bi-cart-plus"></i> Kosárba</a>
                </div>

            </div>
        </div>
        <div class="row my-3 border-top">
            <div class="col-12 py-3">
                <h3 class="text-uppercase fw-bold fs-5">Termék leírása</h3>
                {{ product.description|raw }}
            </div>
        </div>
    </div>

    <script>
        function addToCart(productName, price) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];

            const existing = cart.find(p => p.name === productName);

            if (existing) {
                existing.qty += 1;
            } else {
                cart.push({
                    name: productName,
                    price: price,
                    qty: 1
                });
            }

            localStorage.setItem('cart', JSON.stringify(cart));
            alert("Termék kosárba helyezve.")
        }
    </script>

{% endblock %}
