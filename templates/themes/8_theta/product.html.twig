{% extends 'themes/8_theta/base.html.twig' %}

{% block body %}

    <div class="col-md-9 ms-sm-auto col-lg-10 p-4 p-md-5">

        <h2 class="fw-bold text-uppercase fs-4 border-5 border-bottom border-primary mb-4">{{ title|raw }}</h2>

        <p class="lead fw-bold">{{ product.shortDescription|raw }}</p>

        <p class="badge text-bg-primary fs-6"><i class="bi bi-tag"></i> {{ product.price|format_number(locale='hu') }} {{ product.currency }}</p>

        {{ content|raw }}

        {% if product.mainImage is not null %}
            <img src="/media/{{ product.mainImage.originalName }}" alt="{{ product.name }}" class="d-block w-100">
        {% endif %}

    </div>

{% endblock %}
