                                        <th>Ár</th>
                                        <th>Kosárba</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for product in products %}
                                        <tr>
                                            <td>
                                                <b>{{ product.name }}</b>
                                                <br>{{ product.description|raw }}
                                            </td>
                                            <td>
                                                {{ product.category.name }}
                                            </td>
                                            <td class="text-end">{{ product.price|format_number(locale='hu') }} {{ product.currency }}</td>
                                            <td class="text-end">
                                                <a href="#" class="btn btn-sm btn-dark btn-fluid" onclick="addToCart({{ product.id }}, '{{ product.name }}', {{ product.price }});"><i class="bi bi-cart-plus"></i> Kosárba</a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
