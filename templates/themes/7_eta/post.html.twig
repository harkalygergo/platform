{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <!-- Breadcrumb -->
    <section class="py-3 bg-light" style="margin-top: 80px;">
        <div class="container">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/" class="text-primary">Főoldal</a></li>
                    <li class="breadcrumb-item"><a href="/kategoria/{{ post.categories.first.slug }}" class="text-primary">{{ post.categories.first.title }}</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ post.title }}</li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Blog Post Content -->
    <section class="py-5">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <article class="blog-post">
                        <!-- Post Header -->
                        <header class="post-header mb-5">
                            <div class="post-meta mb-3">
                                <span class="badge bg-primary me-2">{{ post.categories.first.title }}</span>
                                <span class="text-muted">{{ post.createdAt|format_datetime() }}</span>
                                <span class="text-muted ms-3">5 perc olvasás</span>
                            </div>
                            <h1 class="display-4 fw-bold mb-3">{{ post.title|raw }}</h1>
                            <div class="post-stats d-flex align-items-center mb-4">
                                <span class="text-muted me-4"><i class="bi bi-eye me-1"></i>{{ post.viewCount }} megtekintés</span>
                                <!--span class="text-muted me-4"><i class="bi bi-chat me-1"></i>8 hozzászólás</span>
                                <span class="text-muted"><i class="bi bi-heart me-1"></i>24 kedvelés</span-->
                            </div>
                            {% if post.featuredImage is not null %}
                                <div class="post-featured-image">
                                    <img src="/media/{{ post.featuredImage.originalName }}" alt="{{ post.title }}" class="img-fluid rounded shadow">
                                </div>
                            {% endif %}
                        </header>

                        <!-- Post Content -->
                        <div class="post-content">

                            {{ post.content|raw }}
                        </div>

                        <!-- Post Footer -->
                        <footer class="post-footer mt-5 pt-4 border-top">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <div class="post-tags">
                                        <span class="fw-bold me-2">Címkék:</span>
                                        <a href="#" class="btn btn-outline-secondary btn-sm me-1">#detox</a>
                                        <a href="#" class="btn btn-outline-secondary btn-sm me-1">#juice</a>
                                        <a href="#" class="btn btn-outline-secondary btn-sm me-1">#egészség</a>
                                        <a href="#" class="btn btn-outline-secondary btn-sm">#életmód</a>
                                    </div>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <div class="social-share">
                                        <span class="fw-bold me-2">Ossza meg:</span>
                                        <a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=https://{{ website.domain }}/{{ post.categories.first.slug }}/{{ post.slug }}" class="btn btn-outline-primary btn-sm me-1">
                                            <i class="bi bi-facebook text-white"></i>
                                        </a>
                                        <a target="_blank" href="https://twitter.com/intent/tweet?url=https://{{ website.domain }}/{{ post.categories.first.slug }}/{{ post.slug }}&text=" class="btn btn-outline-primary btn-sm me-1">
                                            <i class="bi bi-twitter-x text-white"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </footer>
                    </article>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <div class="sidebar">
                        <!-- Author Card -->
                        <div class="sidebar-card card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <div class="author-info text-center">
                                    <div class="author-avatar mb-3">
                                        <i class="fas fa-user-circle fa-4x text-success"></i>
                                    </div>
                                    <h5 class="fw-bold">Dr. Képes Ildikó Anna</h5>
                                    <p class="text-muted mb-3">Orvos, szakértő</p>
                                    <p class="small">1990 Általános Orvosi diploma
                                        1996 Háziorvostan Szakvizsga
                                        1999 Foglalkozás-egészségügy Szakvizsga
                                        2001 Fizioterápia szakvizsga
                                        2004 Hagyományos Kínai Orvoslás vizsga
                                        2013 Kozmetikai Akupunktúra</p>
                                    <div class="author-social">
                                        <a href="#" class="text-success me-2"><i class="fab fa-linkedin"></i></a>
                                        <a href="#" class="text-success me-2"><i class="fab fa-facebook"></i></a>
                                        <a href="#" class="text-success"><i class="fab fa-twitter"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
