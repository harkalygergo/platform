{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <!-- Blog Post Content -->
    <section class="py-5 border-top">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <article class="blog-post">
                        <!-- Post Header -->
                        <div class="post-header mb-5">
                            <div class="post-meta mb-3">
                                <span class="badge bg-primary me-2">
                                    <a href="/kategoria/{{ post.categories.first.slug }}" class="text-decoration-none text-white">
                                        <i class="bi bi-folder"></i> {{ post.categories.first.title }}
                                    </a>
                                </span>
                                <span class="text-muted small"><i class="bi bi-alarm me-1"></i> {{ post.createdAt|format_datetime() }}</span>
                                <span class="text-muted small ms-3"><i class="bi bi-book me-1"></i> 5 perc olvasás</span>
                                <span class="text-muted small ms-3"><i class="bi bi-eye me-1"></i> {{ post.viewCount }} megtekintés</span>
                            </div>
                            <h1 class="display-6 fw-bold mb-3">{{ post.title|raw }}</h1>
                            <!--div class="post-stats d-flex align-items-center mb-4">
                                <span class="text-muted me-4"><i class="bi bi-eye me-1"></i>{{ post.viewCount }} megtekintés</span>
                                <span class="text-muted me-4"><i class="bi bi-chat me-1"></i>8 hozzászólás</span>
                                <span class="text-muted"><i class="bi bi-heart me-1"></i>24 kedvelés</span>
                            </div-->

                            <p class="lead mb-4">{{ post.leadDescription }}</p>

                            {% if post.featuredImage is not null %}
                                <div class="post-featured-image text-center">
                                    <img src="/media/{{ post.featuredImage.originalName }}" alt="{{ post.title }}" class="img-fluid rounded shadow">
                                </div>
                            {% endif %}
                        </div>

                        <!-- Post Content -->
                        <div class="post-content">

                            {{ post.content|raw }}
                        </div>

                        <!-- Post Footer -->
                        <footer class="post-footer mt-5 pt-4 border-top">
                            <div class="row align-items-center">
                                <div class="col-md-10">
                                    <div class="post-tags">
                                        <span class="fw-bold me-2">Címkék:</span>
                                        {% if post.metaKeywords %}
                                            {% for keyword in post.metaKeywords|split(',') %}
                                                <a href="#" class="btn btn-outline-secondary btn-sm me-1">#{{ keyword|trim }}</a>
                                            {% endfor %}
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-md-2 text-md-end">
                                    <div class="social-share">
                                        <a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=https://{{ website.domain }}/{{ post.categories.first.slug }}/{{ post.slug }}" class="btn btn-outline-primary btn-sm me-1">
                                            <i class="bi bi-facebook text-white"></i>
                                        </a>
                                        <a target="_blank" href="https://twitter.com/intent/tweet?url=https://{{ website.domain }}/{{ post.categories.first.slug }}/{{ post.slug }}&text=" class="btn btn-outline-primary btn-sm me-1">
                                            <i class="bi bi-twitter-x text-white"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </footer>
                    </article>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <div class="sidebar">
                        <!-- Author Card -->
                        <div class="sidebar-card card border-0 shadow-sm mb-4">
                            <div class="card-body p-4">
                                <div class="author-info text-center">
                                    <div class="author-avatar mb-3">
                                        <img src="https://www.vitalitashaz.hu/media/dr-kepes-ildiko-anna-vitalitashaz-bogacs.jpg" alt="Author" class="img-fluid rounded-circle">
                                    </div>
                                    <h5 class="fw-bold">Dr. Képes Ildikó Anna</h5>
                                    <p class="text-muted mb-3">Orvos, szakértő</p>
                                    <ul class="list-unstyled list-inline mb-0">
                                        <li>1990: Általános Orvosi diploma</li>
                                        <li>1996: Háziorvostan Szakvizsga</li>
                                        <li>1999: Foglalkozás-egészségügy Szakvizsga</li>
                                        <li>2001: Fizioterápia szakvizsga</li>
                                        <li>2004: Hagyományos Kínai Orvoslás vizsga</li>
                                        <li>2013: Kozmetikai Akupunktúra</li>
                                    </ul>
                                    <div class="author-social">
                                        <a href="#" class="text-success me-2"><i class="fab fa-linkedin"></i></a>
                                        <a href="#" class="text-success me-2"><i class="fab fa-facebook"></i></a>
                                        <a href="#" class="text-success"><i class="fab fa-twitter"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
