{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <!-- Blog Posts Grid -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center m-5">
                    <h2 class="display-5 fw-bold mb-3">{{ category.title }}</h2>
                </div>
            </div>
            <div class="row g-4">

                {% for post in category.posts %}
                    <div class="col-lg-4">
                        <div class="blog-card card h-100 border-0 shadow-sm">
                            {% if post.featuredImage is not null %}
                                <div class="blog-image">
                                    <img alt="{{ post.title }}" src="/media/{{ post.featuredImage.originalName }}">
                                </div>
                            {% endif %}
                            <div class="card-body p-4">
                                <div class="post-meta mb-3">
                                    <span class="badge bg-primary me-2">{{ post.categories.first.title }}</span>
                                    <span class="text-muted">{{ post.createdAt|format_datetime() }}</span>
                                </div>
                                <h5 class="card-title fw-bold">{{ post.title|raw }}</h5>
                                <p class="card-text">{{ post.metaDescription|raw }}</p>
                                <div class="post-stats d-flex align-items-center mb-3">
                                    <span class="text-muted me-3"><i class="bi bi-eye me-1"></i>856</span>
                                    <span class="text-muted"><i class="bi bi-heart me-1"></i>12</span>
                                </div>
                                <a href="/{{ category.slug }}/{{ post.slug }}" class="btn btn-outline-primary text-white">elolvasom &raquo;</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>

        </div>
    </section>

    <!-- Popular Tags -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h3 class="fw-bold mb-4">Népszerű címkék</h3>
                    <div class="tags d-flex flex-wrap justify-content-center gap-2">
                        <a href="#" class="btn btn-outline-secondary btn-sm">#detox</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#juice</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#wellness</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#egészség</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#yoga</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#meditáció</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#táplálkozás</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#receptek</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#életmód</a>
                        <a href="#" class="btn btn-outline-secondary btn-sm">#bogács</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
