{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <div class="bg-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120"><path fill="#a945ba" fill-opacity="1" d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path></svg>
    </div>


    <div class="bg-primary text-white">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center">
                    <h1 class="display-4 fw-bold mb-3">{{ category.title }}</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white overflow-hidden">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 1440 120"
            style="transform: rotate(180deg); display:block;"
        >
            <path
                fill="#a945ba"
                fill-opacity="1"
                d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z">
            </path>
        </svg>
    </div>

    <section class="py-5">
        <div class="container">
            {{ category.content|raw }}
        </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row g-4">

                {% for post in category.posts %}
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="blog-card card h-100 border-0 shadow-sm">
                            {% if post.featuredImage is not null %}
                                <div class="blog-image">
                                    <img loading="lazy" class="img-fluid" alt="{{ post.title }}" src="/media/{{ post.featuredImage.originalName }}">
                                </div>
                            {% endif %}
                            <div class="card-body p-4">
                                <!--div class="post-meta mb-3">
                                    <span class="badge bg-primary me-2">{{ post.categories.first.title }}</span>
                                    <span class="text-muted">{{ post.createdAt|format_datetime() }}</span>
                                </div-->
                                <a href="/{{ category.slug }}/{{ post.slug }}" class="text-decoration-none text-dark">
                                    <h5 class="card-title fw-bold">{{ post.title|raw }}</h5>
                                </a>
                                <p class="card-text">{{ post.leadDescription|raw }}</p>
                                <!--div class="post-stats d-flex align-items-center mb-3">
                                    <span class="text-muted me-3"><i class="bi bi-eye me-1"></i>{{ post.viewCount }}</span>
                                    <span class="text-muted"><i class="bi bi-heart me-1"></i>12</span>
                                </div-->
                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>

        </div>
    </section>

{% endblock %}
