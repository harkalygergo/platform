{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <!-- Featured Post -->
    <section class="py-5">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center mb-5">
                    <h2 class="display-5 fw-bold mb-3">Kiemelt cikk</h2>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12">
                    <div class="featured-post card border-0 shadow-lg">
                        <div class="row g-0">
                            <div class="col-lg-6">
                                <img src="https://images.unsplash.com/photo-1544551763-46a013bb70d5?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" class="img-fluid h-100 object-cover" alt="Detox program">
                            </div>
                            <div class="col-lg-6">
                                <div class="card-body p-5">
                                    <div class="post-meta mb-3">
                                        <span class="badge bg-success me-2">Detox</span>
                                        <span class="text-muted">2024. január 15.</span>
                                    </div>
                                    <h3 class="card-title fw-bold mb-3">Miért fontos a detox és hogyan kezdjük el?</h3>
                                    <p class="card-text lead">A modern életmód során rengeteg káros anyag halmozódik fel a szervezetünkben. A detox programok segítenek megtisztítani a testet és újraéledni a természetes energiát.</p>
                                    <p class="card-text">Ebben a cikkben megismerheti a detox alapjait, a juice fasting előnyeit és hogyan készüljön fel egy ilyen programra. Megosztjuk a legfontosabb tippeket és tanácsokat a sikeres detox programhoz.</p>
                                    <div class="post-stats d-flex align-items-center mb-3">
                                        <span class="text-muted me-3"><i class="fas fa-eye me-1"></i>1,234 megtekintés</span>
                                        <span class="text-muted me-3"><i class="fas fa-comment me-1"></i>8 hozzászólás</span>
                                        <span class="text-muted"><i class="fas fa-heart me-1"></i>24 kedvelés</span>
                                    </div>
                                    <a href="post.html" class="btn btn-success">Tovább olvasom</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Blog Posts Grid -->
