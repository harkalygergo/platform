{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}

    <div class="bg-white pt-5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120"><path fill="#a945ba" fill-opacity="1" d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path></svg>
    </div>

    <div class="bg-primary text-white">
        <div class="container py-5">
            <div class="row align-items-center">
                <div class="col-lg-8 mx-auto text-center">
                    <h1 class="display-4 fw-bold mb-3">{{ page.title }}</h1>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white overflow-hidden">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 1440 120"
            style="transform: rotate(180deg); display:block;"
        >
            <path
                fill="#a945ba"
                fill-opacity="1"
                d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z">
            </path>
        </svg>
    </div>

    <section class="py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12">
                    {% if page.featuredImage %}
                        <div class="mb-4">
                            <img src="/media/{{ page.featuredImage.originalName }}" alt="{{ title }}" class="img-fluid rounded-5">
                        </div>
                    {% endif %}
                    {{ content|raw }}
                </div>
            </div>
        </div>
    </section>

{% endblock %}
