<!-- CTA Section -->
<section class="py-5 bg-primary text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="display-6 fw-bold mb-3">Készen állsz az új életedre?</h2>
                <p class="lead mb-0">Foglald le a helyed a következő léböjtkúra programunkra és indulj el az egészséges életmód útján!</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/idopontfoglalas" class="btn btn-dark btn-lg"><i class="bi bi-calendar-week"></i> Foglalás most</a>
            </div>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="bg-dark text-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <h5 class="fw-bold mb-3">
                    <i class="fas fa-leaf text-success me-2"></i>
                    {{ website.title }}
                </h5>
                <p class="text-light">{{ website.description }}</p>
                <div class="social-links">
                    <a href="#" class="text-white me-3"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
            <div class="col-lg-4">
                <h6 class="fw-bold mb-3">Navigáció</h6>
                <ul class="list-unstyled">
                    {% for menu in menus %}
                        <li><a href="{{ menu.slug }}" class="text-light text-decoration-none">{{menu.title}}</a></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col-lg-4">
                <h6 class="fw-bold mb-3">Kapcsolat</h6>
                <ul class="list-unstyled">
                    <li class="text-light mb-2">
                        <i class="bi bi-pin text-primary me-2"></i>
                        Bogács, Magyarország
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-phone text-primary me-2"></i>
                        {{ website.phone }}
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-envelope text-primary me-2"></i>
                        {{ website.email }}
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-globe text-primary me-2"></i>
                        {{ website.domain }}
                    </li>
                </ul>
            </div>
        </div>
        <hr class="my-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <p class="mb-0 text-light">
                    &copy; {{ "now"|date("Y") }} {{ website.title }}. Minden jog fenntartva.
                </p>
            </div>
            <div class="col-md-6 text-md-end">
                <a href="#" class="text-light text-decoration-none me-3">Adatvédelmi irányelvek</a>
                <a href="#" class="text-light text-decoration-none">Felhasználási feltételek</a>
            </div>
        </div>
    </div>
</footer>
