<div class="bg-white">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 120"><path fill="#a945ba" fill-opacity="1" d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path></svg>
</div>

<div class="bg-primary text-white">

    <!-- TOP WAVE -->

    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="display-6 fw-bold mb-3">Készen álls az új életére?</h2>
                <p class="lead mb-0">Foglalja le a helyét a következő léböjtkúra programunkra és induljon el az egészséges életmód útján!</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/idopontfoglalas" class="btn btn-dark btn-lg"><i class="bi bi-calendar-week"></i> Foglalás most</a>
            </div>
        </div>
    </div>

</div>

<!-- Footer -->
<footer class="bg-dark text-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-3">
                <h5 class="fw-bold mb-3">
                    {{ website.title }}
                </h5>
                <p class="text-light">{{ website.description }}</p>
                <div class="social-links">
                    <a href="#" class="text-white me-3"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="text-white me-3"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
            <div class="col-lg-3">
                <h6 class="fw-bold mb-3">Menü</h6>
                <ul class="list-unstyled">
                    {% for menu in menus %}
                        <li><a href="{{ menu.slug }}" class="text-light text-decoration-none">{{menu.title}}</a></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col-lg-3">
                <h6 class="fw-bold mb-3">Oldalak</h6>
                <ul class="list-unstyled">
                    {% for page in pages %}
                        <li><a href="{{ page.slug }}" class="text-light text-decoration-none">{{page.title}}</a></li>
                    {% endfor %}
                </ul>
            </div>
            <div class="col-lg-3">
                <h6 class="fw-bold mb-3">Kapcsolat</h6>
                <ul class="list-unstyled">
                    <li class="text-light mb-2">
                        <i class="bi bi-pin text-primary me-2"></i>
                        {{ website.address }}
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-phone text-primary me-2"></i>
                        {{ website.phone }}
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-envelope text-primary me-2"></i>
                        {{ website.email }}
                    </li>
                    <li class="text-light mb-2">
                        <i class="bi bi-globe text-primary me-2"></i>
                        {{ website.domain }}
                    </li>

                    {% if website.facebook %}
                        <li class="text-light mb-2">
                            <a href="{{ website.facebook }}" target="_blank">
                                <i class="bi bi-facebook"></i>
                                <span class="text-light text-decoration-none small">{{ website.facebook }}</span>
                            </a>
                        </li>
                    {% endif %}
                    {% if website.instagram %}
                        <li class="text-light mb-2">
                            <a href="{{ website.instagram }}" target="_blank">
                                <i class="bi bi-instagram"></i>
                                <span class="text-light text-decoration-none small">{{ website.instagram }}</span>
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
        <hr class="my-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <p class="mb-0 text-light">
                    &copy; {{ "now"|date("Y") }} {{ website.title }}. Minden jog fenntartva.
                </p>
            </div>
            <div class="col-md-6 text-md-end">
                <a href="#" class="text-light text-decoration-none me-3">Adatvédelmi irányelvek</a>
                <a href="#" class="text-light text-decoration-none">Felhasználási feltételek</a>
            </div>
        </div>
    </div>
</footer>
