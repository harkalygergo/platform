{% extends 'themes/7_eta/base.html.twig' %}

{% block body %}
    <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            <svg viewBox="0 0 1440 120" class="wave-top" preserveAspectRatio="none">
                <!--path fill="white"
                      d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,53.3C1120,43,1280,53,1360,58.7L1440,64V120H0Z">
                </path-->
                <path fill="white" fill-opacity="1" d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path>
            </svg>
            <div class="carousel-item active">
                <img src="/media/vitalitashaz-bogacs.jpg" class="d-block w-100" alt="...">
            </div>
            <div class="carousel-item">
                <img src="/media/vitalitashaz-bogacs-bejarat_2.jpeg" class="d-block w-100" alt="...">
            </div>-
            <div class="carousel-item">
                <img src="/media/vitalitashaz-bogacs-bejarat_3.jpeg" class="d-block w-100" alt="...">
            </div>
            <svg viewBox="0 0 1440 120" class="wave">
                <!--path fill="white"
                      d="M0,64L80,74.7C160,85,320,107,480,101.3C640,96,800,64,960,53.3C1120,43,1280,53,1360,58.7L1440,64V120H0Z">
                </path-->
                <path fill="white" fill-opacity="1" d="M0,64L80,53.3C160,43,320,21,480,37.3C640,53,800,107,960,117.3C1120,128,1280,96,1360,80L1440,64L1440,320L1360,320C1280,320,1120,320,960,320C800,320,640,320,480,320C320,320,160,320,80,320L0,320Z"></path>
            </svg>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>


    <!-- Features Section -->
    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card text-center p-4 h-100">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-leaf-fill text-primary display-2"></i>
                        </div>
                        <h4>Természetes léböjt</h4>
                        <p>Friss gyümölcsökből és zöldségekből készült juice-okkal tisztítsd meg a testedet természetes módon.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center p-4 h-100">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-flower3 text-primary display-2"></i>
                        </div>
                        <h4>Pihentető környezet</h4>
                        <p>Bogács gyógyvizei és a természet csendje segít a teljes regenerálódásban és relaxációban.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center p-4 h-100">
                        <div class="feature-icon mb-3">
                            <i class="bi bi-heart-fill text-primary display-2"></i>
                        </div>
                        <h4>Egészséges életmód</h4>
                        <p>Tanulj meg egészséges életmódot és kapcsolódj vissza a természethez és önmagadhoz.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Programs Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center mb-5">
                    <h2 class="display-5 fw-bold mb-3">Léböjtkúra programjaink</h2>
                    <p class="lead">Válassz a 6, 8 vagy 10 napos programjaink közül, és indulj el az egészséges életmód útján.</p>
                </div>
            </div>
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="program-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="program-badge bg-primary text-white rounded-pill px-3 py-1 mb-3 d-inline-block">
                                6 napos program
                            </div>
                            <h4 class="card-title">Kezdő léböjt</h4>
                            <p class="card-text">Tökéletes választás azoknak, akik először próbálják ki a juice fasting-et. Enyhe bevezetés a detox világába.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Friss juice-ok naponta</li>
                                <li><i class="fas fa-check text-success me-2"></i>Yoga és meditáció</li>
                                <li><i class="fas fa-check text-success me-2"></i>Természetjárás</li>
                                <li><i class="fas fa-check text-success me-2"></i>Egészségtanácsadás</li>
                            </ul>
                            <div class="program-price mt-4">
                                <span class="h4 text-success">120.000 Ft-tól</span>
                                <small class="text-muted d-block">személyenként</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="program-card card h-100 border-0 shadow-sm position-relative">
                        <div class="position-absolute top-0 start-50 translate-middle">
                            <span class="badge bg-warning text-dark">Népszerű</span>
                        </div>
                        <div class="card-body p-4">
                            <div class="program-badge bg-primary text-white rounded-pill px-3 py-1 mb-3 d-inline-block">
                                8 napos program
                            </div>
                            <h4 class="card-title">Intenzív léböjt</h4>
                            <p class="card-text">Mérsékelt program mélyebb tisztításhoz és hosszabb regenerálódáshoz. Ideális a tapasztaltabbaknak.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Friss juice-ok naponta</li>
                                <li><i class="fas fa-check text-success me-2"></i>Yoga és meditáció</li>
                                <li><i class="fas fa-check text-success me-2"></i>Természetjárás</li>
                                <li><i class="fas fa-check text-success me-2"></i>Egészségtanácsadás</li>
                                <li><i class="fas fa-check text-success me-2"></i>Masszázs kezelés</li>
                            </ul>
                            <div class="program-price mt-4">
                                <span class="h4 text-success">143.000 Ft-tól</span>
                                <small class="text-muted d-block">személyenként</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="program-card card h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="program-badge bg-primary text-white rounded-pill px-3 py-1 mb-3 d-inline-block">
                                10 napos program
                            </div>
                            <h4 class="card-title">Teljes Regenerálódás</h4>
                            <p class="card-text">Legteljesebb program a maximális detox hatásért és hosszú távú egészséges életmód kialakításához.</p>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-check text-success me-2"></i>Friss juice-ok naponta</li>
                                <li><i class="fas fa-check text-success me-2"></i>Yoga és meditáció</li>
                                <li><i class="fas fa-check text-success me-2"></i>Természetjárás</li>
                                <li><i class="fas fa-check text-success me-2"></i>Egészségtanácsadás</li>
                                <li><i class="fas fa-check text-success me-2"></i>Masszázs kezelés</li>
                                <li><i class="fas fa-check text-success me-2"></i>Egyéni tanácsadás</li>
                            </ul>
                            <div class="program-price mt-4">
                                <span class="h4 text-success">176.000 Ft-tól</span>
                                <small class="text-muted d-block">személyenként</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-5">
                <a href="/lebojtkura/lebojtkura-idopontok" class="btn btn-primary btn-lg">Összes program megtekintése</a>
            </div>
        </div>
    </section>

    <!-- About Preview Section -->
    <section class="py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h2 class="display-5 fw-bold mb-4">Miért a Vitalitásház?</h2>
                    <p class="lead mb-4">Bogács gyógyvizei és a természet csendje egyedülálló környezetet biztosít programjainkhoz.</p>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-thermometer-half fa-2x text-success me-3"></i>
                                <div>
                                    <h6 class="mb-1">Gyógyvizek</h6>
                                    <small class="text-muted">Természetes gyógyhatás</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-mountain fa-2x text-success me-3"></i>
                                <div>
                                    <h6 class="mb-1">Természeti környezet</h6>
                                    <small class="text-muted">Csendes, pihentető</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-user-md fa-2x text-success me-3"></i>
                                <div>
                                    <h6 class="mb-1">Szakértő csapat</h6>
                                    <small class="text-muted">Tapasztalt szakemberek</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-home fa-2x text-success me-3"></i>
                                <div>
                                    <h6 class="mb-1">Kényelmes szállás</h6>
                                    <small class="text-muted">Modern felszereltség</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <a href="about.html" class="btn btn-outline-primary">Többet szeretnék tudni</a>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="about-image">
                        <img src="/media/vitalitashaz-bogacs.jpg" alt="Vitalitásház Bogács" class="img-fluid rounded shadow">
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- Testimonials Section -->
    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center mb-5">
                    <h2 class="display-5 fw-bold mb-3">Vendégeink véleménye</h2>
                    <p class="lead">Olvasd el, mit mondanak rólunk azok, akik már átélték a detox programjainkat.</p>
                </div>
            </div>
            <div class="row g-4">

                {% for testimonial in instance.testimonials %}
                    <div class="col-lg-4">
                        <div class="testimonial-card card h-100 border-0 shadow-sm">
                            <div class="card-body p-4">
                                <div class="testimonial-rating mb-3">
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <i class="bi bi-star-fill text-warning"></i>
                                </div>
                                {{ testimonial.content|raw }}
                                <div class="testimonial-author d-flex align-items-center mt-3">
                                    <div class="author-avatar me-3">
                                        <i class="fas fa-user-circle fa-2x text-success"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">{{ testimonial.title }}</h6>
                                        <!--small class="text-muted">Budapest</small-->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>
        </div>
    </section>
{% endblock %}
