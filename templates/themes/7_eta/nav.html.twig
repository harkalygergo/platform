<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-light bg-white py-4 py-lg-5">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">
            {% if website.logo is not null %}
                <img class="ms-0" alt="{{ website.title }} logo" src="/media/{{ website.logo.originalName }}">
            {% endif %}
            {{ website.title|raw }}
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">

                {% for menu in menus %}
                    {% if menu.parent is null %}
                        {% if menu.hasChildren() %}
                            <li class="nav-item px-2 dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="servicesDropdown" role="button" data-bs-toggle="dropdown">
                                    {{ menu.title }}
                                </a>
                                <ul class="dropdown-menu">
                                    {% for child in menu.children %}
                                        {% if child.status %}
                                            <li><a class="dropdown-item" href="{{ child.slug }}" target="{{ child.target }}">{{ child.title }}</a></li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item px-2">
                                <a class="nav-link" href="{{ menu.slug }}" target="{{ menu.target }}">{{ menu.title }}</a>
                            </li>
                        {% endif %}
                    {% endif %}
                {% endfor %}
                <li class="nav-item px-1">
                    <a class="btn btn-primary ms-2" href="/idopontfoglalas">Időpontfoglalás</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
