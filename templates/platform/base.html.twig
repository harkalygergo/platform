<body class="bg-light h-100">

    <div class="d-flex w-100 align-items-stretch min-vh-100">

        {% include 'platform/backend/v1/partials/_sidebar.html.twig' %}

        <div class="flex-grow-1">
            {% include 'platform/backend/_header.html.twig' %}

            {% block main %}
            {% endblock %}

