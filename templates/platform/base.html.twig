    <script src="https://cdn.brandcomstudio.com/vendor/components/jquery/jquery.min.js"></script>
    <script src="https://cdn.brandcomstudio.com/vendor/twbs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.brandcomstudio.com/node_modules/summernote/dist/summernote-bs5.min.js"></script>
    <script src="https://cdn.brandcomstudio.com/node_modules/summernote/dist/lang/summernote-en-US.min.js"></script>
    <script src="https://cdn.brandcomstudio.com/node_modules/summernote/dist/lang/summernote-hu-HU.min.js"></script>
    <script src="https://cdn.brandcomstudio.com/node_modules/jquery-datetimepicker/build/jquery.datetimepicker.full.min.js"></script>

    <script>
        function slugify(text) {
            return text.toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        window.addEventListener("load", (event) => {
            const slugTargets = document.querySelectorAll('.slugTarget');
            slugTargets.forEach(function(input) {
                input.addEventListener('focus', function() {
                    if (this.value === '') {
                        const slugSource = document.getElementsByClassName("slugSource")["0"];
                        this.value = slugify(slugSource.value);
                    }
                });
            });
        });

        // Define the custom Prettify button
        var PrettifyButton = function(context) {
            var ui = $.summernote.ui;

            var button = ui.button({
                contents : '<i class="note-icon-magic"></i> Prettify',
                tooltip  : 'Format / Prettify HTML code',
                click    : function() {
                    // Get the current raw HTML from the editor
                    var html = context.invoke('code');

                    // Beautify it
                    var pretty = html_beautify(html, {
                        indent_size          : 2,
                        wrap_line_length     : 120,
                        preserve_newlines    : false,
                        indent_inner_html    : true,
                        extra_liners         : ['head', 'body', '/html'],
                        unformatted          : [],   // format everything, including <script>/<style>
                        content_unformatted  : [],
                    });

                    // Write it back into the editor
                    context.invoke('code', pretty);

                    // If codeview is active, update CodeMirror instance too
                    var $cm = context.layoutInfo.codable.data('CodeMirrorInstance');
                    if ($cm) {
                        $cm.setValue(pretty);
                        $cm.refresh();
                    }
                }
            });

            return button.render();
        };

        jQuery(document).ready(function() {
            jQuery('.summernote').summernote({
                lang: 'hu-HU',
                codeviewFilter: false,
                codeviewIframeFilter: false,
                toolbar:[
                    ['style', ['style']],
                    ['font',     ['bold', 'italic', 'underline', 'strikethrough', 'superscript', 'subscript', 'clear']],
                    ['fontname', ['fontname']],
                    ['fontsize', ['fontsize']],
                    ['fontsizeunit', ['fontsizeunit']], // px / em / rem unit toggle
                    ['color',    ['forecolor', 'backcolor']], // separate pickers
                    ['para', ['ul','ol','paragraph','height']],
                    ['table', ['table']],
                    ['insert',   ['link', 'picture', 'video', 'hr']],
                    ['view',     ['fullscreen', 'codeview', 'help']],
                    ['misc', ['undo','redo']],
                    ['custom', ['prettify']]
                ],
                height: 300,
                codemirror: {
                    mode         : 'text/html',   // HTML syntax highlighting
                    htmlMode     : true,
                    lineNumbers  : true,          // show gutter line numbers
                    lineWrapping : true,          // soft wrap long lines
                    theme        : 'monokai',     // any CodeMirror theme
                    matchBrackets: true,          // highlight matching brackets
                    indentWithTabs: true,
                    tabSize      : 2,
                },
                buttons: {
                    prettify: PrettifyButton,     // <-- register the button
                }
            });

            jQuery.datetimepicker.setLocale('hu');

            jQuery('.datetimepicker').datetimepicker({
                /*
                i18n:{
                    hu:{
                        months:[
                            'Januar','Februar','März','April',
                            'Mai','Juni','Juli','August',
                            'September','Oktober','November','Dezember',
                        ],
                        dayOfWeek:[
                            "So.", "Mo", "Di", "Mi",
                            "Do", "Fr", "Sa.",
                        ]
                    }
                },
                */
                format: 'Y-m-d H:i'
                //format:'unixtime'
                //timepicker:false,
                //format:'d.m.Y'
            });
        });


        function sidebarToggle() {
            const icons = document.getElementById('sidebar_icons');
            const menu = document.getElementById('sidebar_menu');
            const header_toggle_icon = document.getElementById('header_toggle_icon');
            if (icons.style.display === 'none') {
                icons.style.display = 'block';
                menu.style.display = 'block';
                header_toggle_icon.setAttribute("style", "display:none !important");
            } else {
                icons.style.display = 'none';
                menu.style.display = 'none';
                header_toggle_icon.setAttribute("style", "display:flex !important");
            }
        }

        function sidebarMenu(section)
        {
            let sectionMenu = document.getElementById("sidebar_menu_"+section.toLowerCase());

            // check if it is not null
            if (!sectionMenu)
            {
                return;
            }

            if(sectionMenu.style.display === "none" || sectionMenu.style.display === "")
            {
                closeAllSidebarMenus();
                sectionMenu.style.display = "block";
            }
        }

        function closeAllSidebarMenus()
        {
            let menus = document.getElementsByClassName("sidebar_menu_section");
            for(let i = 0; i < menus.length; i++)
            {
                menus[i].style.display = "none";
            }
        }

        function showActiveSidebarMenu()
        {
            let activeSidebarItem = document.getElementsByClassName("nav-link active")["0"];
            if (activeSidebarItem) {
                activeSidebarItem.parentElement.parentElement.parentElement.classList += " show ";
                sidebarMenu(activeSidebarItem.parentElement.parentElement.parentElement.parentElement.parentElement.parentElement.id.replace("sidebar_menu_", ""));
            }
        }

        window.addEventListener("load", (event) => {
            showActiveSidebarMenu();
        });

    </script>

</body>
