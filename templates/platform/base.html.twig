    <script>
        function slugify(text) {
            return text.toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-')
                .replace(/^-|-$/g, '');
        }

        window.addEventListener("load", (event) => {
            const slugTargets = document.querySelectorAll('.slugTarget');
            slugTargets.forEach(function(input) {
                input.addEventListener('focus', function() {
                    if (this.value === '') {
                        const slugSource = document.getElementsByClassName("slugSource")["0"];
                        this.value = slugify(slugSource.value);
                    }
                });
            });
        });

        var VariableButton = function(context) {
            var ui = $.summernote.ui;

            var variables = {
                'Order: number': '[order___number]',
                'Order: created at': '[order___created_at]',
                'Order: total': '[order___total]',
                'Order: currency': '[order__currency]',
                'Order: customer first name': '[order__first_name]',
                'Order: customer last name': '[order__last_name]',
                'Order: customer phone': '[order__phone]',
                'Order: customer email': '[order__email]',
                'Order: shipping method': '[order__shipping_method]',
                'Order: shipping address': '[order__shipping_address]',
                'Order: billing country': '[order__billing_country]',
                'Order: billing zip': '[order__billing_zip]',
                'Order: billing city': '[order__billing_city]',
                'Order: payment status': '[order__payment_status]',
                'Order: status': '[order__status]',
            };

            var items = Object.keys(variables).map(function(label) {
                return '<a class="dropdown-item" href="#" data-value="' + variables[label] + '">' + label + '</a>';
            }).join('');

            return ui.buttonGroup([
                ui.button({
                    className: 'dropdown-toggle',
                    contents: 'Variables <span class="caret"></span>',
                    tooltip: 'Insert variable',
                    data: {
                        toggle: 'dropdown'
                    }
                }),
                ui.dropdown({
                    items: items,
                    callback: function($dropdown) {
                        $dropdown.find('.dropdown-item').on('click', function(e) {
                            e.preventDefault();

                            var value = $(this).data('value');

                            context.invoke('editor.restoreRange');
                            context.invoke('editor.focus');
                            context.invoke('editor.insertText', value);
                        });
                    }
                })
            ]).render();
        };

        // Define the custom Prettify button
        var PrettifyButton = function(context) {
            var ui = $.summernote.ui;

            var button = ui.button({
                contents : '<i class="note-icon-magic"></i> Prettify',
                tooltip  : 'Format / Prettify HTML code',
                click    : function() {
                    // Get the current raw HTML from the editor
                    var html = context.invoke('code');

                    // Beautify it
                    var pretty = html_beautify(html, {
                        indent_size          : 2,
                        wrap_line_length     : 120,
                        preserve_newlines    : false,
                        indent_inner_html    : true,
                        extra_liners         : ['head', 'body', '/html'],
                        unformatted          : [],   // format everything, including <script>/<style>
                        content_unformatted  : [],
                    });

                    // Write it back into the editor
                    context.invoke('code', pretty);

                    // If codeview is active, update CodeMirror instance too
                    var $cm = context.layoutInfo.codable.data('CodeMirrorInstance');
                    if ($cm) {
                        $cm.setValue(pretty);
                        $cm.refresh();
                    }
                }
            });

            return button.render();
        };

        jQuery(document).ready(function() {
            jQuery('.summernote').summernote({
                lang: 'hu-HU',
                codeviewFilter: false,
                codeviewIframeFilter: false,
                toolbar:[
                    ['style', ['style']],
                    ['font',     ['bold', 'italic', 'underline', 'strikethrough', 'superscript', 'subscript', 'clear']],
                    ['fontname', ['fontname']],
                    ['fontsize', ['fontsize']],
                    ['fontsizeunit', ['fontsizeunit']], // px / em / rem unit toggle
                    ['color',    ['forecolor', 'backcolor']], // separate pickers
                    ['para', ['ul','ol','paragraph','height']],
                    ['table', ['table']],
                    ['insert',   ['link', 'picture', 'video', 'hr']],
                    ['view',     ['fullscreen', 'codeview', 'help']],
                    ['misc', ['undo','redo']],
                    ['custom', ['variables', 'prettify']]
                ],
                height: 300,
                codemirror: {
                    mode         : 'text/html',   // HTML syntax highlighting
                    htmlMode     : true,
                    lineNumbers  : true,          // show gutter line numbers
                    lineWrapping : true,          // soft wrap long lines
                    theme        : 'monokai',     // any CodeMirror theme
                    matchBrackets: true,          // highlight matching brackets
                    indentWithTabs: true,
                    tabSize      : 2,
                },
                buttons: {
                    prettify: PrettifyButton,
                    variables: VariableButton
                }
            });

            jQuery.datetimepicker.setLocale('hu');

            jQuery('.datetimepicker').datetimepicker({
                /*
                i18n:{
                    hu:{
                        months:[
